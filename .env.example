# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Coral MCP (stdio transport). The app spawns `coral mcp-stdio` and calls its
# `sql` tool. CORAL_COMMAND is the coral binary (or absolute path); CORAL_ARGS
# is a JSON list; CORAL_CWD is where Coral loads source specs from (defaults to
# the app's working directory, which contains coral/sources/*.yaml).
CORAL_COMMAND=coral
CORAL_ARGS=["mcp-stdio"]
CORAL_CWD=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#dev-intel

# Webhook secrets
GITHUB_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=

# Default Slack channel for event-driven alerts
ENGINEERING_CHANNEL=#engineering

# Default repo / project the agents query (GitHub & Sentry APIs require these).
# NOTE: the Jira/GitHub/Sentry *data-source credentials* live in Coral's env
# (see coral/README.md), not here. These just tell the agents which repo/project.
GITHUB_OWNER=
GITHUB_REPO=
SENTRY_PROJECT=
